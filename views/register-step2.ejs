<!DOCTYPE html>
<html lang="en">
  <head>

    <meta charset="UTF-8">
    <title><%= title %></title>

    <meta name="description" content="Registration part 2 - verification to Atlasphere">
    <meta name="keywords" content="Registration part 2 - verification, form">
    <meta name="author" content="Group 4">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">

</head>

<body>
  <!-- include header and navbar template from partials -->
  <%- include('../partials/navbar') %>
  
  <!-- each page's content is injected here -->
  <div class="container-fluid">
    <%- 
        <!-- Registration verification form > new users have to enter a verification code which they received via email -->
        <section>
            <h3>We've sent you an e-mail</h3>
            <p>Please enter the numeric code you have received in your e-mail:</p>
            <p>The code expires in 5 minutes.</p>
            <p><a href="#">Resend the code?</a></p>

            <!-- Form where users have to enter a numeric code which they reveived by e-mail to verify and conlcude their account -->
            <form action="#" method="post">
            <input class="input" type="text" inputmode="numeric" maxlength="1" size="5">
            <input class="input" type="text" inputmode="numeric" maxlength="1" size="5">
            <input class="input" type="text" inputmode="numeric" maxlength="1" size="5">
            <input class="input" type="text" inputmode="numeric" maxlength="1" size="5">
            <input class="input" type="text" inputmode="numeric" maxlength="1" size="5">
            <input class="input" type="text" inputmode="numeric" maxlength="1" size="5"><br>
            
            <input type="button" id="verify" name="verify" value="Verify/Submit">
            </form>
        </section>
    
    %>
  </div>
 
  <!-- include footer template from partials -->
  <%- include('..partials/footer') %>
  <script src="/js/bootstrap.bundle.min.js"> </script>
  
  </body>
</html>
