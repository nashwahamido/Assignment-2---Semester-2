<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Email — Atlasphere</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<%- include('partials/navbar', { user: null }) %>

<!-- Verification Page — matches Figma wireframe -->
<div class="auth-page">
  <div class="auth-bg">
    <img src="https://images.unsplash.com/photo-1511884642898-4c92249e20b6?w=1600&q=80" alt="Waterfall landscape">
  </div>

  <div class="auth-card verify-card">
    <h1>We've sent you an email</h1>
    <p class="verify-subtitle">Enter the 6-digit code to verify your account</p>

    <form action="/auth/verify" method="post">
      <div class="code-inputs">
        <input type="text" maxlength="1" name="code1" autocomplete="off" autofocus>
        <input type="text" maxlength="1" name="code2" autocomplete="off">
        <input type="text" maxlength="1" name="code3" autocomplete="off">
        <input type="text" maxlength="1" name="code4" autocomplete="off">
        <input type="text" maxlength="1" name="code5" autocomplete="off">
        <input type="text" maxlength="1" name="code6" autocomplete="off">
      </div>

      <button type="submit" class="btn btn-primary">Verify</button>
    </form>

    <div class="auth-footer mt-2">
      <p><a href="#" class="resend-link">Expired code? Send code again?</a></p>
    </div>
  </div>
</div>

<script>
  // Auto-focus next input on code entry
  document.querySelectorAll('.code-inputs input').forEach((input, i, inputs) => {
    input.addEventListener('input', (e) => {
      if (e.target.value && i < inputs.length - 1) inputs[i + 1].focus();
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace' && !e.target.value && i > 0) inputs[i - 1].focus();
    });
  });
</script>

</body>
</html>