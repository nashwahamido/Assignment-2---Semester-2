<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome to Atlasphere</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<%- include('partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<!-- Hero Section — matches Figma "Landing Page" -->
<header class="hero-header">
  <div class="hero-figure">
    <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1600&q=80" alt="Mountain landscape with traveller">
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1>Welcome to<br>Atlasphere</h1>
    <div class="action-buttons" style="justify-content: flex-start;">
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/groups/create/country" class="btn btn-secondary">Create a Trip</a>
        <a href="/groups" class="btn btn-primary">View My Trips</a>
      <% } else { %>
        <a href="/auth/register" class="btn btn-secondary">Register</a>
        <a href="/auth/login" class="btn btn-primary">Login</a>
      <% } %>
    </div>
  </div>
</header>

<!-- Features Section -->
<main class="main-content">
  <section class="features-section">
    <h2>Why Choose Atlasphere?</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🗺️</div>
        <h3>Easy Planning</h3>
        <p>Plan your trips with friends in one place</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">👥</div>
        <h3>Collaborate</h3>
        <p>Vote on activities and make decisions together</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📅</div>
        <h3>Organize</h3>
        <p>Create itineraries and manage your schedule</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">💬</div>
        <h3>Communicate</h3>
        <p>Chat with your travel group in real-time</p>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>

</body>
</html>