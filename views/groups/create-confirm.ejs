<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Group Created — Atlasphere</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<!-- Group Created — matches Figma "Your Country group has been created!" -->
<div class="group-creation-page">
  <div class="group-creation-bg">
    <img src="https://images.unsplash.com/photo-1509316785289-025f5b846b35?w=1600&q=80" alt="Desert landscape at sunset">
  </div>

  <div class="group-creation-content" style="text-align: left;">
    <div class="confirmed-layout">
      <div class="confirmed-left">
        <h1>Your &ldquo;Country&rdquo; group<br>has been created!</h1>

        <div style="margin-top: 32px;">
          <label style="font-size: 15px; font-weight: 500; color: var(--text-secondary); display: block; margin-bottom: 8px;">Search for a friend</label>
          <div class="search-input">
            <span class="search-icon">🔍</span>
            <input type="text" placeholder="Search...">
          </div>
        </div>

        <p style="color: var(--text-secondary); margin: 12px 0;">or</p>

        <a href="#" class="btn btn-secondary" style="width: auto;">Share Link</a>
      </div>

      <div class="confirmed-right">
        <div class="upload-circle" style="width: 140px; height: 140px;">
          <span class="upload-icon">🖼️</span>
          <input type="file" accept="image/*">
        </div>
        <a href="#" class="resend-link" style="font-size: 13px;">Upload Profile Picture</a>
      </div>
    </div>

    <div class="setup-actions" style="justify-content: flex-start; margin-top: 40px;">
      <a href="/groups/1" class="btn btn-primary">Go to Group</a>
    </div>
  </div>
</div>

</body>
</html>