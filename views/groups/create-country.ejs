<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Choose Destination - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/setup-desert.jpg" alt="Desert landscape"></div>
    <div class="framed-box__content">
      <div class="group-creation-content">
        <h1>What is your destination<br>for your group holiday?</h1>

        <div class="search-input" style="margin: 24px auto;">
          <span class="search-icon">&#128269;</span>
          <input type="text" id="countrySearch" placeholder="Search...">
        </div>

        <form action="/groups/create/city" method="get" id="countryForm">
          <input type="hidden" name="country" id="selectedCountry" value="">
          <div class="destination-grid" id="countryGrid">
            <div class="destination-card" data-value="france"><div class="card-img">&#128444;</div><span class="card-name">Country Name</span></div>
            <div class="destination-card" data-value="italy"><div class="card-img">&#128444;</div><span class="card-name">Country Name</span></div>
            <div class="destination-card" data-value="spain"><div class="card-img">&#128444;</div><span class="card-name">Country Name</span></div>
            <div class="destination-card" data-value="germany"><div class="card-img">&#128444;</div><span class="card-name">Country Name</span></div>
            <div class="destination-card" data-value="portugal"><div class="card-img">&#128444;</div><span class="card-name">Country Name</span></div>
            <div class="destination-card" data-value="greece"><div class="card-img">&#128444;</div><span class="card-name">Country Name</span></div>
          </div>
          <div class="setup-actions" style="margin-top: 32px;">
            <button type="submit" class="btn btn-primary">Next</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('#countryGrid .destination-card').forEach(function(card){
    card.addEventListener('click',function(){
      document.querySelectorAll('#countryGrid .destination-card').forEach(function(c){c.classList.remove('selected');});
      card.classList.toggle('selected');
      document.getElementById('selectedCountry').value=card.dataset.value||'';
    });
  });
  document.getElementById('countrySearch').addEventListener('input',function(e){
    var q=e.target.value.toLowerCase();
    document.querySelectorAll('#countryGrid .destination-card').forEach(function(card){
      card.style.display=card.querySelector('.card-name').textContent.toLowerCase().includes(q)?'':'none';
    });
  });
</script>
</body>
</html>
