<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cities Visited - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/profile-created-coast.jpg" alt="Coast"></div>
    <div class="framed-box__content">
      <div class="sel-content">
        <div class="sel-header"><h1>What cities have you visited?</h1><a href="/profile/confirmed" class="skip-btn">Skip</a></div>
        <div class="sel-search"><span>&#128269;</span><input type="text" placeholder="Search" id="citySearch"></div>
        <form action="/profile/confirmed" method="get">
          <div class="flag-grid">
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="dub"><span class="flag-card__img">&#127470;&#127466;</span><span class="flag-card__name">Dublin</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="vie"><span class="flag-card__img">&#127462;&#127481;</span><span class="flag-card__name">Vienna</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="rom"><span class="flag-card__img">&#127470;&#127481;</span><span class="flag-card__name">Rome</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="bru"><span class="flag-card__img">&#127463;&#127466;</span><span class="flag-card__name">Brussels</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="par"><span class="flag-card__img">&#127467;&#127479;</span><span class="flag-card__name">Paris</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="zur"><span class="flag-card__img">&#127464;&#127469;</span><span class="flag-card__name">Zurich</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="lon"><span class="flag-card__img">&#127988;&#917607;&#917602;&#917605;&#917614;&#917607;&#917631;</span><span class="flag-card__name">London</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="gla"><span class="flag-card__img">&#127988;&#917607;&#917602;&#917619;&#917603;&#917620;&#917631;</span><span class="flag-card__name">Glasgow</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="ams"><span class="flag-card__img">&#127475;&#127473;</span><span class="flag-card__name">Amsterdam</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="ber"><span class="flag-card__img">&#127465;&#127466;</span><span class="flag-card__name">Berlin</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="hel"><span class="flag-card__img">&#127467;&#127470;</span><span class="flag-card__name">Helsinki</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="cities[]" value="sto"><span class="flag-card__img">&#127480;&#127466;</span><span class="flag-card__name">Stockholm</span></label>
          </div>
          <div class="sel-actions"><button type="submit" class="btn-next">Next</button></div>
        </form>
      </div>
    </div>
  </div>
</div>
<script>var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);document.getElementById('citySearch').addEventListener('input',function(e){var v=e.target.value.toLowerCase();document.querySelectorAll('.flag-card').forEach(function(c){c.style.display=c.textContent.toLowerCase().includes(v)?'':'none';});});</script>
</body>
</html>
