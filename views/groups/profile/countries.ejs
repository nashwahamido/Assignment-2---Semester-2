<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Countries Visited - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>
<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/registration-lake.jpg" alt="Lake"></div>
    <div class="framed-box__content">
      <div class="sel-content">
        <div class="sel-header"><h1>What countries have you visited?</h1><a href="/setup/cities" class="skip-btn">Skip</a></div>
        <div class="sel-search"><span>&#128269;</span><input type="text" placeholder="Search" id="countrySearch"></div>
        <form action="/setup/cities" method="get">
          <div class="flag-grid">
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="ie"><span class="flag-card__img">&#127470;&#127466;</span><span class="flag-card__name">Ireland</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="at"><span class="flag-card__img">&#127462;&#127481;</span><span class="flag-card__name">Austria</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="it"><span class="flag-card__img">&#127470;&#127481;</span><span class="flag-card__name">Italy</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="be"><span class="flag-card__img">&#127463;&#127466;</span><span class="flag-card__name">Belgium</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="fr"><span class="flag-card__img">&#127467;&#127479;</span><span class="flag-card__name">France</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="ch"><span class="flag-card__img">&#127464;&#127469;</span><span class="flag-card__name">Switzerland</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="gb-eng"><span class="flag-card__img">&#127988;&#917607;&#917602;&#917605;&#917614;&#917607;&#917631;</span><span class="flag-card__name">England</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="gb-sct"><span class="flag-card__img">&#127988;&#917607;&#917602;&#917619;&#917603;&#917620;&#917631;</span><span class="flag-card__name">Scotland</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="nl"><span class="flag-card__img">&#127475;&#127473;</span><span class="flag-card__name">The Netherlands</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="de"><span class="flag-card__img">&#127465;&#127466;</span><span class="flag-card__name">Germany</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="fi"><span class="flag-card__img">&#127467;&#127470;</span><span class="flag-card__name">Finland</span></label>
            <label class="flag-card" onclick="this.classList.toggle('selected')"><input type="checkbox" name="countries[]" value="se"><span class="flag-card__img">&#127480;&#127466;</span><span class="flag-card__name">Sweden</span></label>
          </div>
          <div class="sel-actions"><button type="submit" class="btn-next">Next</button></div>
        </form>
      </div>
    </div>
  </div>
</div>
<script>var s=localStorage.getItem('atlasphere-theme');if(s)document.documentElement.setAttribute('data-theme',s);document.getElementById('countrySearch').addEventListener('input',function(e){var v=e.target.value.toLowerCase();document.querySelectorAll('.flag-card').forEach(function(c){c.style.display=c.textContent.toLowerCase().includes(v)?'':'none';});});</script>
</body>
</html>
