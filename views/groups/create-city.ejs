<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Choose Cities - Atlasphere</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<div class="framed-page">
  <div class="framed-box">
    <div class="framed-box__bg"><img src="/images/setup-desert.jpg" alt="Desert landscape"></div>
    <div class="framed-box__content">
      <div class="group-creation-content">
        <h1>Which cities in &ldquo;Country&rdquo;?</h1>
        <p>Select at least one city</p>

        <div class="search-input" style="margin: 24px auto;">
          <span class="search-icon">&#128269;</span>
          <input type="text" id="citySearch" placeholder="Search...">
        </div>

        <form action="/groups/create/days" method="get">
          <input type="hidden" name="cities" id="selectedCities" value="">
          <div class="destination-grid" id="cityGrid">
            <div class="destination-card" data-value="city1"><div class="card-img">&#128444;</div><span class="card-name">City Name</span></div>
            <div class="destination-card" data-value="city2"><div class="card-img">&#128444;</div><span class="card-name">City Name</span></div>
            <div class="destination-card" data-value="city3"><div class="card-img">&#128444;</div><span class="card-name">City Name</span></div>
            <div class="destination-card" data-value="city4"><div class="card-img">&#128444;</div><span class="card-name">City Name</span></div>
            <div class="destination-card" data-value="city5"><div class="card-img">&#128444;</div><span class="card-name">City Name</span></div>
            <div class="destination-card" data-value="city6"><div class="card-img">&#128444;</div><span class="card-name">City Name</span></div>
          </div>
          <div class="setup-actions" style="margin-top: 32px;">
            <button type="submit" class="btn btn-primary">Next</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('#cityGrid .destination-card').forEach(function(card){
    card.addEventListener('click',function(){card.classList.toggle('selected');});
  });
  document.getElementById('citySearch').addEventListener('input',function(e){
    var q=e.target.value.toLowerCase();
    document.querySelectorAll('#cityGrid .destination-card').forEach(function(card){
      card.style.display=card.querySelector('.card-name').textContent.toLowerCase().includes(q)?'':'none';
    });
  });
</script>
</body>
</html>
