<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= (typeof user !== 'undefined' && user) ? user.username + "'s Profile" : 'Profile' %> — Atlasphere</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<div class="profile-page">
  <h1>Profile</h1>

  <figure class="iprofileImg">
    <img class="personalProfileImg"
         src="<%= (typeof user !== 'undefined' && user && user.profile_image) ? user.profile_image : '' %>"
         alt="Profile picture"
         onerror="this.style.display='none'">
  </figure>

  <div class="username-pill">
    <%= (typeof user !== 'undefined' && user) ? user.username : 'Guest' %>
  </div>

  <div class="stats-row">
    <div class="stat">
      <p>Countries visited</p>
      <span><%= (typeof user !== 'undefined' && user) ? (user.countries_visited || 0) : 0 %></span>
    </div>
    <div class="stat">
      <p>Cities visited</p>
      <span><%= (typeof user !== 'undefined' && user) ? (user.cities_visited || 0) : 0 %></span>
    </div>
    <div class="stat">
      <p>Groups created</p>
      <span><%= (typeof user !== 'undefined' && user) ? (user.groups_created || 0) : 0 %></span>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

</body>
</html>