<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload Profile Picture — Atlasphere</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null }) %>

<div class="setup-page">
  <div class="setup-bg">
    <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1600&q=80" alt="Mountain sunset">
  </div>
  <div class="setup-content text-center">
    <h1>Upload Profile Picture</h1>
    <div class="upload-circle">
      <span class="upload-icon">🖼️</span>
      <input type="file" accept="image/*">
    </div>
    <div class="setup-actions">
      <a href="/profile" class="btn btn-primary">Save</a>
      <a href="/profile" class="skip-link">Skip</a>
    </div>
  </div>
</div>

</body>
</html>